{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./dist",
        "baseUrl": "./src",
        "paths": {
            "@/*": [
                "*"
            ]
        },
        "strict": true,
        "types": [
            "node"
        ],
        "moduleResolution": "node"
    },
    "include": [
        "src/**/*"
    ]
}